# ============================================================
# SRE Agent Demo — environment template
# Copy to .env, fill in your own values, then: `source .env`
# .env is gitignored — never commit real values.
# ============================================================

# ----- Azure subscription / tenant / identity -----
# Get from: `az account show --query '{sub:id, tenant:tenantId}' -o table`
export AZURE_SUBSCRIPTION_ID=""
export AZURE_TENANT_ID=""

# ----- Naming (feel free to change; must be globally unique for ACR) -----
export AZURE_RG="rg-sre-agent-demo"
export AZURE_LOCATION="eastus2"
# ACR name: 5-50 alphanumeric, globally unique. Append a suffix.
export ACR_NAME="acrsredemo$RANDOM"
export AKS_NAME="aks-sre-demo"
export LAW_NAME="law-sre-demo"
export APPI_NAME="appi-sre-demo"
export K8S_NAMESPACE="sre-demo"

# ----- Filled in by deploy.sh after resources exist -----
# You can leave these empty on first run; the script writes them back.
export ACR_LOGIN_SERVER=""
export APPI_CS=""
export LAW_ID=""
export INGRESS_IP=""
